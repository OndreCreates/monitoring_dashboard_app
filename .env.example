DB_HOST=localhost
DB_PORT=5432
DB_NAME=monitoring_dashboard
DB_USER=
DB_PASSWORD=
SPRING_PROFILE=dev

# Optional — Slack/Discord webhook for alert notifications. Empty disables it.
# docker-compose substitutes this from .env automatically — keep the real
# value only in your local .env (gitignored), never commit a live URL here.
WEBHOOK_URL=
WEBHOOK_FORMAT=slack
